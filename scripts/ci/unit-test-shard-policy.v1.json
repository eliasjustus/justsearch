{
  "kind": "justsearch-unit-test-shard-policy.v1",
  "version": 1,
  "budgetsAreAdvisory": true,
  "lanes": [
    {
      "lane": "app-ui",
      "requiredCheck": "Unit tests (app-ui)",
      "artifact": "unit-test-attribution-app-ui",
      "runnerLabel": "ubuntu-latest/app-ui",
      "owner": "app and UI hosted unit evidence",
      "platformClass": "mixed/needs targeted experiment",
      "platformRiskNotes": [
        "Includes Windows-sensitive app-util and app-launcher behavior.",
        "Includes runtime manifest, logging, headless eval, and app-instance locking surfaces.",
        "Migrated to ubuntu-latest (tempdoc 668, advisory runs done). Genuinely Windows-specific tests (@Tag windows) run on the windows-native-tests lane."
      ],
      "gradleTasks": [
        ":modules:app-agent:test",
        ":modules:app-agent-api:test",
        ":modules:app-api:test",
        ":modules:app-api-tck:test",
        ":modules:app-config:test",
        ":modules:app-launcher:test",
        ":modules:app-observability:test",
        ":modules:app-services:test",
        ":modules:app-util:test",
        ":modules:ui:test"
      ],
      "localCommand": "./gradlew.bat :modules:app-agent:test :modules:app-agent-api:test :modules:app-api:test :modules:app-api-tck:test :modules:app-config:test :modules:app-launcher:test :modules:app-observability:test :modules:app-services:test :modules:app-util:test :modules:ui:test -PskipWebBuild=true --console=plain",
      "advisoryBudgets": {
        "maxSummedSuiteSeconds": 300,
        "slowSuiteWarnSeconds": 60,
        "maxSkipped": 50
      }
    },
    {
      "lane": "search-worker",
      "requiredCheck": "Unit tests (search-worker)",
      "artifact": "unit-test-attribution-search-worker",
      "runnerLabel": "ubuntu-latest/search-worker",
      "owner": "search and worker hosted unit evidence",
      "platformClass": "mixed/needs targeted experiment",
      "platformRiskNotes": [
        "Includes Tika/PDF fixture-adjacent behavior, Lucene filesystem behavior, index locking, and worker model discovery.",
        "Contains path and worker-runtime assumptions that need targeted proof before a platform move.",
        "Migrated to ubuntu-latest (tempdoc 668). Cross-platform issues fixed (isCloudPlaceholder attr read, path-separator handling, blank-prefix guard, IndexRootLock spawn); timing-sensitive DrainAndClose method runs @Tag windows on the windows-native-tests lane."
      ],
      "gradleTasks": [
        ":modules:adapters-lucene:test",
        ":modules:configuration:test",
        ":modules:core:test",
        ":modules:core-contracts:test",
        ":modules:indexer-worker:test",
        ":modules:indexing:test",
        ":modules:ipc-common:test",
        ":modules:worker-core:test",
        ":modules:worker-services:test"
      ],
      "localCommand": "./gradlew.bat :modules:adapters-lucene:test :modules:configuration:test :modules:core:test :modules:core-contracts:test :modules:indexer-worker:test :modules:indexing:test :modules:ipc-common:test :modules:worker-core:test :modules:worker-services:test -PskipWebBuild=true --console=plain",
      "advisoryBudgets": {
        "maxSummedSuiteSeconds": 300,
        "slowSuiteWarnSeconds": 60,
        "maxSkipped": 50
      }
    },
    {
      "lane": "platform-contracts",
      "requiredCheck": "Unit tests (platform-contracts)",
      "artifact": "unit-test-attribution-platform-contracts",
      "runnerLabel": "ubuntu-latest/platform-contracts",
      "owner": "platform, inference, contract, and governance hosted unit evidence",
      "platformClass": "mixed/needs targeted experiment",
      "platformRiskNotes": [
        "Includes GPU bridge, ORT/common, app-inference, system-test substrate, and native/runtime assumptions.",
        "Migrated to ubuntu-latest (tempdoc 668). GPU/ORT tests self-skip via @EnabledOnOs; the timing-sensitive LlamaServerOps crash-telemetry method runs @Tag windows on the windows-native-tests lane.",
        "Advisory --continue Linux runs were used to enumerate and fix the portability tail before flipping."
      ],
      "gradleTasks": [
        ":modules:ai-backend:test",
        ":modules:api-contract-projection-java:test",
        ":modules:app-inference:test",
        ":modules:benchmarks:test",
        ":modules:dead-code-audit:test",
        ":modules:extension-substrate:test",
        ":modules:gpu-bridge:test",
        ":modules:infra-core:test",
        ":modules:ort-common:test",
        ":modules:prompt-support:test",
        ":modules:reranker:test",
        ":modules:ssot-tools:test",
        ":modules:system-tests:test",
        ":modules:telemetry:test",
        ":modules:test-support:test"
      ],
      "localCommand": "./gradlew.bat :modules:ai-backend:test :modules:api-contract-projection-java:test :modules:app-inference:test :modules:benchmarks:test :modules:dead-code-audit:test :modules:extension-substrate:test :modules:gpu-bridge:test :modules:infra-core:test :modules:ort-common:test :modules:prompt-support:test :modules:reranker:test :modules:ssot-tools:test :modules:system-tests:test :modules:telemetry:test :modules:test-support:test -PskipWebBuild=true --console=plain",
      "advisoryBudgets": {
        "maxSummedSuiteSeconds": 300,
        "slowSuiteWarnSeconds": 60,
        "maxSkipped": 50
      }
    }
  ]
}

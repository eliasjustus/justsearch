{
  "kind": "justsearch-workflow-signal-policy.v1",
  "version": 3,
  "defaultStaleDays": 14,
  "workflows": [
    {
      "name": "CI",
      "path": ".github/workflows/ci.yml",
      "class": "public-hosted-fact-lanes",
      "expectedTriggers": ["workflow_dispatch", "pull_request", "push"],
      "owner": "ADR-0044 / public hosted CI fact lanes",
      "failureDefault": "product-regression",
      "staleDays": 14,
      "blocking": true,
      "advisory": false,
      "requiredStatusChecks": [
        "Public claims",
        "License and notices",
        "Build (no model blobs)",
        "Unit tests (app-ui)",
        "Unit tests (search-worker)",
        "Unit tests (platform-contracts)",
        "Secret scan",
        "DCO"
      ]
    },
    {
      "name": "CLA Assistant",
      "path": ".github/workflows/cla.yml",
      "class": "contributor-provenance",
      "expectedTriggers": ["issue_comment", "pull_request_target"],
      "owner": "CLA.md / CONTRIBUTING.md",
      "failureDefault": "contributor-policy",
      "staleDays": 14,
      "blocking": true,
      "advisory": false,
      "requiredStatusChecks": ["cla-assistant"]
    },
    {
      "name": "Build Installer",
      "path": ".github/workflows/build-installer.yml",
      "class": "release-gate",
      "expectedTriggers": ["workflow_dispatch"],
      "owner": "tempdoc 374 / Production-Reality Verification",
      "failureDefault": "release-blocking-failure",
      "staleDays": 14,
      "blocking": true,
      "advisory": false
    },
    {
      "name": "Docs lint",
      "path": ".github/workflows/docs-lint.yml",
      "class": "docs-manual-gate",
      "expectedTriggers": ["workflow_dispatch"],
      "owner": "documentation maintenance",
      "failureDefault": "product-regression",
      "staleDays": 7,
      "blocking": true,
      "advisory": false
    },
    {
      "name": "CodeQL",
      "path": ".github/workflows/codeql.yml",
      "class": "security-scan",
      "expectedTriggers": ["workflow_dispatch"],
      "owner": "security automation",
      "failureDefault": "security-signal",
      "staleDays": 30,
      "blocking": false,
      "advisory": true
    },
    {
      "name": "Phase 3 Observability Nightly",
      "path": ".github/workflows/phase-3-observability-nightly.yml",
      "class": "scheduled-quality-signal",
      "expectedTriggers": ["workflow_dispatch"],
      "owner": "tempdocs 400/404 when jseval gate is reached; workflow signal governance for setup drift",
      "failureDefault": "workflow-assumption-drift",
      "staleDays": 7,
      "blocking": false,
      "advisory": true
    },
    {
      "name": "Dependabot Updates",
      "path": "github-managed",
      "class": "dependency-automation",
      "expectedTriggers": ["dependabot"],
      "owner": "dependency maintenance",
      "failureDefault": "workflow-assumption-drift",
      "staleDays": 30,
      "blocking": false,
      "advisory": true
    },
    {
      "name": "Dependency Graph",
      "path": "github-managed",
      "class": "dependency-automation",
      "expectedTriggers": ["dynamic"],
      "owner": "dependency maintenance",
      "failureDefault": "workflow-assumption-drift",
      "staleDays": 30,
      "blocking": false,
      "advisory": true
    }
  ]
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://justsearch.dev/schemas/grpc-retry-policy-profiles.v1.schema.json",
  "title": "gRPC Retry Policy Profiles v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "kind",
    "schemaVersion",
    "generatedAt",
    "profiles"
  ],
  "properties": {
    "kind": {
      "const": "grpc-retry-policy-profiles.v1"
    },
    "schemaVersion": {
      "const": 1
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "profiles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "policyId",
          "owner",
          "maxRetriesDefault",
          "initialBackoffMs",
          "maxBackoffMs",
          "backoffMultiplier",
          "retryableStatusCodes",
          "surfaces"
        ],
        "properties": {
          "policyId": {
            "type": "string",
            "minLength": 1
          },
          "owner": {
            "type": "string",
            "minLength": 1
          },
          "maxRetriesDefault": {
            "type": "integer",
            "minimum": 0
          },
          "maxRetriesSource": {
            "type": "string",
            "minLength": 1
          },
          "initialBackoffMs": {
            "type": "integer",
            "minimum": 0
          },
          "maxBackoffMs": {
            "type": "integer",
            "minimum": 0
          },
          "backoffMultiplier": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "retryableStatusCodes": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "surfaces": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
}

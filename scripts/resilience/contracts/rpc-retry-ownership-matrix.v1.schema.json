{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://justsearch.dev/schemas/rpc-retry-ownership-matrix.v1.schema.json",
  "title": "RPC Retry Ownership Matrix v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "kind",
    "schemaVersion",
    "generatedAt",
    "scope",
    "methods"
  ],
  "properties": {
    "kind": {
      "const": "rpc-retry-ownership-matrix.v1"
    },
    "schemaVersion": {
      "const": 1
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "services",
        "expectedMethodCount"
      ],
      "properties": {
        "services": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "expectedMethodCount": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "methods": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/methodRow"
      }
    }
  },
  "$defs": {
    "methodRow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surfaceId",
        "protoFile",
        "service",
        "method",
        "methodFqn",
        "operationClass",
        "idempotencyClass",
        "transportRetryOwner",
        "callerRetryOwner",
        "circuitBreakerOwner",
        "deadlineCategory",
        "retryPolicyId",
        "idempotencyKeySupport",
        "stateSafetyNotes",
        "evidenceRefs"
      ],
      "properties": {
        "surfaceId": {
          "enum": [
            "head-worker"
          ]
        },
        "protoFile": {
          "type": "string",
          "minLength": 1
        },
        "service": {
          "type": "string",
          "minLength": 1
        },
        "method": {
          "type": "string",
          "minLength": 1
        },
        "methodFqn": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9_.]+/[A-Za-z0-9_]+$"
        },
        "operationClass": {
          "enum": [
            "READ",
            "WRITE",
            "CONTROL",
            "DESTRUCTIVE"
          ]
        },
        "idempotencyClass": {
          "enum": [
            "STRICT",
            "EFFECTIVE_RETRY_SAFE",
            "CONDITIONAL",
            "NON_IDEMPOTENT"
          ]
        },
        "transportRetryOwner": {
          "enum": [
            "grpc_service_config",
            "none"
          ]
        },
        "callerRetryOwner": {
          "enum": [
            "none",
            "client_wrapper",
            "workflow_layer"
          ]
        },
        "circuitBreakerOwner": {
          "type": "string",
          "minLength": 1
        },
        "deadlineCategory": {
          "enum": [
            "STANDARD",
            "CONTENT_FETCH",
            "VDU_OPERATION",
            "INDEX_GC",
            "LONG_RUNNING"
          ]
        },
        "retryPolicyId": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "idempotencyKeySupport": {
          "enum": [
            "none",
            "required",
            "optional"
          ]
        },
        "stateSafetyNotes": {
          "type": "string",
          "minLength": 1
        },
        "allowDualRetryOwner": {
          "type": "boolean"
        },
        "evidenceRefs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "transportRetryOwner": {
                "const": "none"
              }
            }
          },
          "then": {
            "properties": {
              "retryPolicyId": {
                "const": null
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "idempotencyClass": {
                "const": "CONDITIONAL"
              }
            }
          },
          "then": {
            "properties": {
              "idempotencyKeySupport": {
                "enum": [
                  "required",
                  "optional"
                ]
              }
            }
          },
          "else": {
            "properties": {
              "idempotencyKeySupport": {
                "const": "none"
              }
            }
          }
        }
      ]
    }
  }
}

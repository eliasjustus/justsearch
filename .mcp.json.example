{
  "mcpServers": {
    "justsearch-dev": {
      "command": "node",
      "args": ["scripts/dev/justsearch-dev-mcp.mjs"]
    },
    "github": {
      "command": "cmd",
      "args": ["/c", "npx", "-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "REPLACE_WITH_YOUR_GITHUB_PAT"
      }
    }
  }
}

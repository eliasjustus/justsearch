{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ssot.justsearch/v1/schemas/indexing/analyzers-catalog.schema.json",
  "title": "Analyzers Catalog v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "analyzers"],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "analyzers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/AnalyzerRef"
      }
    }
  },
  "$defs": {
    "AnalyzerRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "locale", "provider", "components", "fingerprint"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "locale": { "type": "string", "minLength": 1 },
        "provider": { "enum": ["icu", "keyword"], "$comment": "Closed to language-agnostic providers only — no per-language analyzer (stemmer/stopwords/synonyms). Tempdoc 581 / ADR-0043; enforced by the language-agnostic-analysis gate." },
        "components": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "fingerprint": { "type": "string", "pattern": "^[a-f0-9]{64}$", "$comment": "RFC8785 (JCS) canonical descriptor hashed with SHA-256" }
      }
    }
  }
}



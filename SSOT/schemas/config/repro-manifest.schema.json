{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ssot.justsearch/v1/schemas/config/repro-manifest.schema.json",
  "title": "Reproducible Artifacts Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["artifacts"],
  "properties": {
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "sha256"],
        "properties": {
          "path": { "type": "string" },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
        }
      }
    }
  }
}



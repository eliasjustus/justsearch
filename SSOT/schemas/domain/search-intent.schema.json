{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ssot.justsearch/v1/schemas/domain/search-intent.schema.json",
  "title": "SearchIntent v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["limit", "offset", "clauses"],
  "properties": {
    "limit": { "type": "integer", "minimum": 1, "default": 10 },
    "offset": { "type": "integer", "minimum": 0, "default": 0 },
    "highlight": { "type": "boolean" },
    "filters": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mime": { "type": "string" },
        "language": { "type": "string" },
        "timeRange": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "fromMs": { "type": ["integer", "null"], "minimum": 0 },
            "toMs": { "type": ["integer", "null"], "minimum": 0 }
          }
        }
      }
    },
    "sort": {
      "type": "array",
      "items": { "type": "string" }
    },
    "cursor": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["mode", "token"],
      "properties": {
        "mode": { "type": "string" },
        "token": { "type": "string" },
        "expiresAtEpochMs": { "type": ["integer", "null"], "minimum": 0 },
        "extras": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "context": {
      "type": "object",
      "additionalProperties": true,
      "default": {}
    },
    "clauses": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type"],
        "properties": {
          "type": { "type": "string", "pattern": "^[a-z]+$" },
          "field": { "type": "string" },
          "value": { "type": ["string", "number", "boolean"] },
          "tokens": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}



{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/eliasjustus/justsearch/blob/main/governance/agent-hooks.v1.schema.json",
  "title": "Agent-hooks manifest — single authority for hook wiring (tempdoc 592)",
  "type": "object",
  "required": ["kind", "version", "hookDir", "hooks", "bindings"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "kind": { "const": "agent-hooks-manifest.v1" },
    "version": { "type": "integer", "minimum": 1 },
    "comment": { "type": "string" },
    "hookDir": { "type": "string" },
    "hooks": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["file", "role"],
        "additionalProperties": false,
        "properties": {
          "file": { "type": "string", "pattern": "\\.mjs$" },
          "role": { "enum": ["blocking", "advisory", "telemetry"] },
          "bite": {
            "type": "object",
            "required": ["kind"],
            "properties": {
              "kind": { "enum": ["command-signal", "unit"] },
              "stdin": { "type": "object" },
              "transcript": { "type": "array" },
              "expect": {
                "type": "object",
                "properties": {
                  "exitCode": { "type": "integer" },
                  "stdoutIncludes": { "type": "string" }
                },
                "additionalProperties": false
              },
              "test": { "type": "string" },
              "note": { "type": "string" }
            },
            "additionalProperties": false
          }
        }
      }
    },
    "bindings": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["hooks"],
          "additionalProperties": false,
          "properties": {
            "matcher": { "type": "string" },
            "hooks": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["hookId"],
                "additionalProperties": false,
                "properties": {
                  "hookId": { "type": "string" },
                  "if": { "type": "string" },
                  "timeout": { "type": "number" },
                  "async": { "type": "boolean" }
                }
              }
            }
          }
        }
      }
    }
  }
}

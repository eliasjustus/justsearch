{
  "name": "ui-web",
  "version": "0.0.0",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:all": "node scripts/dev-all.cjs",
    "build": "vite build",
    "build:analyze": "node -e \"process.env.ANALYZE='true';require('child_process').execSync('npx vite build',{stdio:'inherit',env:{...process.env,ANALYZE:'true'}})\"",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:strict": "tsc -p tsconfig.strict.json --noEmit",
    "preview": "vite preview",
    "visual:diff": "node scripts/visual-regression.cjs",
    "visual:update-baseline": "node scripts/visual-regression.cjs --update-baseline",
    "test": "playwright test --project=Desktop",
    "test:all": "playwright test",
    "test:gate": "playwright test e2e/gate-smoke.spec.ts --project=Desktop --workers=1",
    "test:guard:testids": "node ../../scripts/ci/check-playwright-hardcoded-testids.mjs --mode gate --root modules/ui-web/e2e",
    "test:mobile": "playwright test --project=Mobile",
    "test:light": "playwright test --project=Desktop --workers=1",
    "test:headed": "playwright test --headed --workers=1",
    "test:debug": "playwright test --debug",
    "test:report": "playwright show-report",
    "test:unit": "vitest",
    "test:unit:run": "vitest run",
    "test:unit:ui": "vitest --ui",
    "test:unit:lockdown": "vitest run --config vitest.config.lockdown.ts",
    "knip": "knip",
    "gen:shape-handlers": "node ../../scripts/codegen/gen-shape-handlers.mjs",
    "gen:wire-schema-types": "node ../../scripts/codegen/gen-wire-schema-types.mjs",
    "gen:liveness-constants": "node ../../scripts/codegen/gen-liveness-constants.mjs",
    "gen:api-client": "node ../../scripts/codegen/gen-api-client.mjs",
    "check:api-client-regen": "node ../../scripts/ci/check-api-client-regen.mjs",
    "check:liveness-constants-regen": "node ../../scripts/ci/check-liveness-constants-regen.mjs",
    "check:liveness-constants-single-authority": "node ../../scripts/ci/check-liveness-constants-single-authority.mjs",
    "check:shape-handler-regen": "node ../../scripts/ci/check-shape-handler-regen.mjs",
    "check:shape-view-coverage": "node ../../scripts/ci/check-shape-view-coverage.mjs",
    "check:wire-schema-types-regen": "node ../../scripts/ci/check-wire-schema-types-regen.mjs",
    "check:wire-type-single-authority": "node ../../scripts/ci/check-wire-type-single-authority.mjs"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.12.1",
    "@bufbuild/protovalidate": "^1.2.0",
    "@endo/module-source": "^1.4.1",
    "@jsonforms/core": "^3.8.0",
    "@juggle/resize-observer": "^3.4.0",
    "@lingui/core": "^6.4.0",
    "@lit-labs/signals": "^0.3.0",
    "@lit-labs/virtualizer": "^2.1.1",
    "@lumino/widgets": "^2.8.0",
    "@tanstack/table-core": "^8.21.3",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-autostart": "^2.5.1",
    "@tauri-apps/plugin-deep-link": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@types/dompurify": "^3.2.0",
    "clsx": "^2.1.1",
    "dompurify": "^3.4.11",
    "lit": "^3.3.3",
    "marked": "^18.0.5",
    "ses": "^2.2.0",
    "virtua": "^0.49.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^10.0.1",
    "@lingui/cli": "^6.4.0",
    "@lingui/vite-plugin": "^6.4.0",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.2",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.56.0",
    "@vitest/ui": "^4.1.9",
    "autoprefixer": "^10.5.2",
    "eslint": "^10.6.0",
    "fast-check": "^4.8.0",
    "globals": "^17.7.0",
    "happy-dom": "^20.10.6",
    "knip": "^6.23.0",
    "pixelmatch": "^7.2.0",
    "pngjs": "^7.0.0",
    "postcss": "^8.5.16",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^4.2.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.2",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "flatted": "^3.4.2",
    "fast-uri": "^3.1.2"
  }
}

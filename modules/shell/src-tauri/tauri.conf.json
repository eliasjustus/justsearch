{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "JustSearch",
  "mainBinaryName": "JustSearch",
  "version": "0.1.0",
  "identifier": "io.justsearch.shell",
  "build": {
    "beforeDevCommand": "npm --prefix ../ui-web run dev -- --host --port 5173",
    "beforeBuildCommand": "npm --prefix ../ui-web run build && ..\\..\\gradlew.bat --no-daemon -p ..\\.. -PskipWebBuild=true :modules:ui:bundleSidecar",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../../ui-web/dist",
    "removeUnusedCommands": true
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "resources": [
      "resources/headless/**/*",
      "resources/vc_redist.x64.exe"
    ],
    "windows": {
      "allowDowngrades": false,
      "webviewInstallMode": {
        "type": "offlineInstaller",
        "silent": true
      },
      "nsis": {
        "installMode": "currentUser",
        "installerHooks": "nsis/installer-hooks.nsh",
        "compression": "zlib"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "deep-link": {
      "mobile": [],
      "desktop": {
        "schemes": ["justsearch"]
      }
    }
  },
  "app": {
    "windows": [
      {
        "title": "JustSearch",
        "width": 1024,
        "height": 700,
        "minWidth": 600,
        "minHeight": 400,
        "decorations": false,
        "transparent": true,
        "resizable": true,
        "center": true,
        "alwaysOnTop": false,
        "shadow": true,
        "visible": false,
        "focus": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: http://asset.localhost blob: data:; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost http://127.0.0.1:*; media-src 'self'"
    }
  }
}



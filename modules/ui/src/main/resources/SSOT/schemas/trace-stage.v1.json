{
  "$schema" : "https://json-schema.org/draft/2020-12/schema",
  "type" : "object",
  "properties" : {
    "cardinality" : {
      "type" : "integer"
    },
    "detail" : {
      "type" : "string"
    },
    "id" : {
      "type" : "string",
      "enum" : [ "query-understanding", "expansion", "correction", "sparse-retrieval", "dense-retrieval", "splade-retrieval", "fusion", "chunk-merge", "branch-fusion", "lambdamart", "cross-encoder", "freshness" ]
    },
    "ms" : {
      "type" : "integer"
    },
    "reason" : {
      "type" : "string"
    },
    "status" : {
      "type" : "string",
      "enum" : [ "executed", "skipped", "disabled", "failed" ]
    }
  }
}

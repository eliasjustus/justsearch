<?xml version="1.0" encoding="UTF-8"?>
<!--
  Logback configuration for the Knowledge Server (indexer-worker).

  Logs are written to file by default to ensure safety in headless environments.
  Console logging is DISABLED by default to prevent pipe buffer deadlocks
  if the parent process stops reading stdout.

  Log directory: ${JUSTSEARCH_DATA_DIR}/logs or ~/.justsearch/logs

  Hot-reload enabled: changes to this file take effect within 30 seconds.
  To temporarily enable DEBUG for the indexing loop, change the logger level
  below — or use POST /api/debug/logging at runtime.
-->
<configuration scan="true" scanPeriod="30 seconds">
  <!--
    Tempdoc 374 alpha.26 hotfix (mirroring the head's logback.xml fix from
    round-15 finding #3): silence Logback's own Joran startup status output
    so worker logs don't begin with ~62 non-JSON INFO lines about Logback
    initializing itself.
  -->
  <statusListener class="ch.qos.logback.core.status.NopStatusListener"/>

  <!-- Property-based configuration -->
  <property name="LOG_DIR" value="${JUSTSEARCH_DATA_DIR:-${user.home}/.justsearch}/logs" />
  <property name="LOG_FILE" value="worker" />

  <!-- Console appender (Optional - Enable only for debugging) -->
  <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
    </encoder>
  </appender>

  <!-- Rolling file appender with structured JSON output -->
  <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
    <file>${LOG_DIR}/${LOG_FILE}.log</file>
    <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
      <fileNamePattern>${LOG_DIR}/${LOG_FILE}-%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
      <maxFileSize>10MB</maxFileSize>
      <maxHistory>7</maxHistory>
      <totalSizeCap>256MB</totalSizeCap>
    </rollingPolicy>
    <encoder class="net.logstash.logback.encoder.LogstashEncoder">
      <shortenedLoggerNameLength>48</shortenedLoggerNameLength>
      <fieldNames>
        <timestamp>@timestamp</timestamp>
      </fieldNames>
      <!-- Include MDC correlation keys per Observability guidance -->
      <includeMdcKeyName>trace_id</includeMdcKeyName>
      <includeMdcKeyName>span_id</includeMdcKeyName>
      <includeMdcKeyName>pipeline_name</includeMdcKeyName>
      <!-- pipeline_hash + budget_profile retired by tempdoc 400 LR2-d (orphan per ADR 0014) -->
      <includeMdcKeyName>request_id</includeMdcKeyName>
      <includeMdcKeyName>stage_id</includeMdcKeyName>
      <customFields>{"service":"indexer-worker"}</customFields>
    </encoder>
  </appender>

  <!-- Async wrapper for file appender (non-blocking writes) -->
  <appender name="ASYNC_FILE" class="ch.qos.logback.classic.AsyncAppender">
    <queueSize>2048</queueSize>
    <discardingThreshold>0</discardingThreshold>
    <neverBlock>true</neverBlock>
    <includeCallerData>false</includeCallerData>
    <appender-ref ref="FILE" />
  </appender>

  <!-- OTel MDC bridge: injects span_id + trace_flags into log events.
       Must wrap ASYNC_FILE (outermost) so OTel context is captured on the originating thread
       before the event is queued for async processing.
       traceIdKey is renamed to avoid conflict with our manual trace_id set by MdcContext.request().
       The library skips ALL injection if the default "trace_id" key already exists in MDC. -->
  <appender name="OTEL_MDC" class="io.opentelemetry.instrumentation.logback.mdc.v1_0.OpenTelemetryAppender">
    <traceIdKey>otel_trace_id</traceIdKey>
    <appender-ref ref="ASYNC_FILE" />
  </appender>

  <!-- Reduce noise from chatty libraries -->
  <logger name="io.grpc" level="WARN" />
  <logger name="io.netty" level="WARN" />
  <logger name="org.apache.lucene" level="WARN" />
  <logger name="org.sqlite" level="WARN" />

  <!-- Application loggers -->
  <logger name="io.justsearch" level="DEBUG" />
  <logger name="io.justsearch.indexerworker" level="INFO" />
  <logger name="io.justsearch.indexerworker.loop" level="INFO" />
  <logger name="io.justsearch.indexerworker.coordination" level="INFO" />

  <!--
    Root logger: File Only
    Console logging is explicitly disabled to prevent "pipe buffer deadlocks"
    when the worker runs as a background process and the parent stops reading stdout.
    To enable console logging for development, uncomment the CONSOLE appender ref below.
  -->
  <root level="INFO">
    <!-- <appender-ref ref="CONSOLE" /> -->
    <appender-ref ref="OTEL_MDC" />
  </root>

</configuration>

modules/*/tmp/

# Browser automation caches (Puppeteer/Chromium)
scripts/**/.local-chromium/
scripts/**/.cache/
# `chrome/` was historically over-broad (intended for browser
# binaries; ended up excluding source `modules/ui-web/src/shell-v0/chrome/`
# which holds the Lit chrome — Stage/Rail/Shell). 477-execution
# critical-analysis caught this. Allow the source chrome dir
# explicitly.
chrome/
!modules/ui-web/src/shell-v0/chrome/
!modules/ui-web/src/shell-v0/chrome/**
**/chrome-linux*/

# Claude Code temporary directories
tmpclaude-*/
nul

# Cargo local config (machine-specific build flags)
**/.cargo/

# Claude Code local settings (may contain tokens or permissions)
.claude/settings.local.json
# Auto-generated compaction state (written by compact-restore.mjs, session-specific)
.claude/rules/compaction-state.md
# Runtime lock files (e.g. .claude/scheduled_tasks.lock) — session-local state;
# committing causes conflicts between concurrent Claude sessions.
.claude/*.lock
.mcp.json

# Local agent evidence captures
agent-review/

# Inference runtime artifacts (model ID written at runtime). Slice 518's
# inference-transitions NDJSON sidecar + head crash-dump writer can also
# land at the repo root when the head launches from there during dev.
modules/app-inference/inference-model-id.txt
/inference-model-id.txt
/crashes/
/telemetry/

# Playwright test result caches
modules/ui-web/test-results-codex/

# Extracted/decompiled Gradle plugin sources (appear at repo root)
net/

# Mangled Windows-path temp files (D：code... with Unicode fullwidth colon)
D*codeJustSearch*
modules/ui/inference-model-id.txt

# Stale compiled classes outside build directories
/io/

# GGUF model files at repo root (should be under models/)
*.gguf


{
  "name": "justsearch",
  "version": "1.0.0",
  "description": "Local‑first desktop search with Lucene, optional local LLM assist, and strong offline/security posture.",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "doctor": "node scripts/dev/doctor.mjs",
    "test:dev-runner": "node scripts/dev/test-dev-runner-runtime-resolution.mjs",
    "lint:md": "markdownlint docs/explanation/**/*.md docs/reference/**/*.md docs/how-to/**/*.md docs/decisions/**/*.md",
    "check:llmstxt": "node scripts/docs/llmstxt-generate.mjs --check",
    "docs:anchor-audit": "node scripts/docs/anchor-audit.mjs --root docs",
    "docs:anchor-audit:write": "node scripts/docs/anchor-audit.mjs --root docs --fix-links"
  },
  "keywords": [],
  "author": "",
  "license": "Apache-2.0",
  "type": "commonjs",
  "overrides": {
    "markdownlint-cli": {
      "minimatch": "^10.2.4"
    },
    "hono": "^4.12.8",
    "@hono/node-server": "^1.19.11",
    "express-rate-limit": "^8.3.1"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "fast-glob": "^3.3.3",
    "gray-matter": "^4.0.3",
    "madge": "^8.0.0",
    "markdownlint-cli": "^0.49.0",
    "toposort": "^2.0.2",
    "zod": "^4.4.3"
  }
}
